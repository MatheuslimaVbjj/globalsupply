  <div class="container footer-grid">
    <div class="footer-brand">
      <a href="../index.html" class="logo">GLOBAL<span>SUPPLY</span></a>
      <p>Sneakers e streetwear premium com entrega rápida em Portugal e Espanha.</p>
      <div class="social-links">
        <a href="https://instagram.com" target="_blank" rel="noopener" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
        <a href="https://tiktok.com" target="_blank" rel="noopener" aria-label="TikTok"><i class="fab fa-tiktok"></i></a>
        <a href="https://wa.me/351910346159" target="_blank" rel="noopener" aria-label="WhatsApp"><i class="fab fa-whatsapp"></i></a>
      </div>
    </div>
    <div class="footer-col">
      <h4>Loja</h4>
      <a href="shop.html">Todos os Produtos</a>
      <a href="shop.html?cat=sneakers">Sneakers</a>
      <a href="shop.html?cat=clothing">Vestuário</a>
    </div>
