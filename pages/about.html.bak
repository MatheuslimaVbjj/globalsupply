    <a href="../index.html" class="logo">GLOBAL<span>SUPPLY</span></a>

    <nav class="nav" id="main-nav">

      <div class="nav-item has-dropdown">
        <button class="nav-link">Sneakers <i class="fas fa-chevron-down nav-chevron"></i></button>
        <div class="mega-menu">
          <div class="mega-col">
            <p class="mega-label">Categorias</p>
            <a href="shop.html?cat=sneakers&sub=low-top" class="mega-link">Low Top</a>
            <a href="shop.html?cat=sneakers&sub=mid-top" class="mega-link">Mid Top</a>
            <a href="shop.html?cat=sneakers&sub=high-top" class="mega-link">High Top</a>
            <a href="shop.html?cat=sneakers&sub=running" class="mega-link">Running / Lifestyle</a>
            <a href="shop.html?cat=sneakers&sub=slides" class="mega-link">Slides &amp; Sandálias</a>
          </div>
          <div class="mega-col">
            <p class="mega-label">Popular</p>
            <a href="shop.html?filter=new" class="mega-link">Novidades</a>
            <a href="shop.html?filter=hot" class="mega-link">Mais Vendidos</a>
            <a href="shop.html?filter=sale" class="mega-link mega-sale">Saldos</a>
          </div>
        </div>
      </div>

      <div class="nav-item has-dropdown">
        <button class="nav-link">Roupa <i class="fas fa-chevron-down nav-chevron"></i></button>
        <div class="mega-menu">
          <div class="mega-col">
            <p class="mega-label">Categorias</p>
            <a href="shop.html?cat=clothing&sub=tshirts" class="mega-link">T-Shirts</a>
            <a href="shop.html?cat=clothing&sub=hoodies" class="mega-link">Hoodies &amp; Sweats</a>
            <a href="shop.html?cat=clothing&sub=pants" class="mega-link">Calças &amp; Shorts</a>
            <a href="shop.html?cat=clothing&sub=jackets" class="mega-link">Casacos &amp; Jackets</a>
            <a href="shop.html?cat=clothing&sub=tracksuits" class="mega-link">Fatos de Treino</a>
          </div>
          <div class="mega-col">
            <p class="mega-label">Popular</p>
            <a href="shop.html?filter=new" class="mega-link">Novidades</a>
            <a href="shop.html?filter=hot" class="mega-link">Mais Vendidos</a>
            <a href="shop.html?filter=sale" class="mega-link mega-sale">Saldos</a>
          </div>
        </div>
      </div>

      <div class="nav-item has-dropdown">
        <button class="nav-link">Acessórios <i class="fas fa-chevron-down nav-chevron"></i></button>
        <div class="mega-menu">
          <div class="mega-col">
            <p class="mega-label">Categorias</p>
            <a href="shop.html?cat=accessories&sub=caps" class="mega-link">Bonés &amp; Gorros</a>
            <a href="shop.html?cat=accessories&sub=socks" class="mega-link">Meias</a>
            <a href="shop.html?cat=accessories&sub=bags" class="mega-link">Mochilas &amp; Bags</a>
            <a href="shop.html?cat=accessories&sub=wallets" class="mega-link">Carteiras</a>
          </div>
          <div class="mega-col">
            <p class="mega-label">Popular</p>
            <a href="shop.html?filter=new" class="mega-link">Novidades</a>
            <a href="shop.html?filter=hot" class="mega-link">Mais Vendidos</a>
            <a href="shop.html?filter=sale" class="mega-link mega-sale">Saldos</a>
          </div>
        </div>
      </div>

      <div class="nav-item"><a href="shop.html?filter=brands" class="nav-link nav-link-plain">Marcas</a></div>
      <div class="nav-item"><a href="shop.html?filter=outfits" class="nav-link nav-link-plain">Outfits</a></div>
      <div class="nav-item"><a href="../index.html#releases" class="nav-link nav-link-plain">Drops</a></div>
      <div class="nav-item"><a href="shop.html?filter=sale" class="nav-link nav-link-plain nav-sale">Saldos</a></div>

    </nav>

    <div class="header-actions">
      <button class="header-icon-btn" aria-label="Pesquisar" onclick="document.getElementById('search-bar').classList.toggle('open')">
        <i class="fas fa-search"></i>
      </button>
      <button class="cart-btn" onclick="openCart()" aria-label="Carrinho">
        <i class="fas fa-shopping-bag"></i>
        <span class="cart-count"></span>
      </button>
      <button class="hamburger" onclick="toggleMobileNav()" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <div class="search-bar" id="search-bar">
    <div class="container">
      <input type="text" placeholder="Pesquisar sneakers, marcas..." id="search-input" autocomplete="off">
      <button onclick="document.getElementById('search-bar').classList.remove('open')"><i class="fas fa-times"></i></button>
    </div>
  </div>
</header>

<!-- MOBILE NAV -->
<nav class="mobile-nav" id="mobile-nav">
  <div class="mobile-nav-header">
    <span class="logo" style="font-family:var(--font-heading);font-size:1.3rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase">GLOBAL<span style="color:var(--accent)">SUPPLY</span></span>
    <button onclick="toggleMobileNav()" style="background:none;border:none;color:var(--white);font-size:1.5rem;cursor:pointer"><i class="fas fa-times"></i></button>
  </div>
  <a href="../index.html" onclick="toggleMobileNav()">Início</a>
  <div class="mob-acc">
    <button class="mob-acc-btn" onclick="toggleMobAcc(this)">Sneakers <i class="fas fa-chevron-down"></i></button>
    <div class="mob-acc-body">
      <a href="shop.html?cat=sneakers&sub=low-top" onclick="toggleMobileNav()">Low Top</a>
      <a href="shop.html?cat=sneakers&sub=mid-top" onclick="toggleMobileNav()">Mid Top</a>
      <a href="shop.html?cat=sneakers&sub=high-top" onclick="toggleMobileNav()">High Top</a>
      <a href="shop.html?cat=sneakers&sub=running" onclick="toggleMobileNav()">Running / Lifestyle</a>
    </div>
  </div>
  <div class="mob-acc">
    <button class="mob-acc-btn" onclick="toggleMobAcc(this)">Roupa <i class="fas fa-chevron-down"></i></button>
    <div class="mob-acc-body">
      <a href="shop.html?cat=clothing&sub=tshirts" onclick="toggleMobileNav()">T-Shirts</a>
      <a href="shop.html?cat=clothing&sub=hoodies" onclick="toggleMobileNav()">Hoodies &amp; Sweats</a>
      <a href="shop.html?cat=clothing&sub=pants" onclick="toggleMobileNav()">Calças &amp; Shorts</a>
    </div>
  </div>
  <div class="mob-acc">
    <button class="mob-acc-btn" onclick="toggleMobAcc(this)">Acessórios <i class="fas fa-chevron-down"></i></button>
    <div class="mob-acc-body">
      <a href="shop.html?cat=accessories&sub=caps" onclick="toggleMobileNav()">Bonés &amp; Gorros</a>
      <a href="shop.html?cat=accessories&sub=socks" onclick="toggleMobileNav()">Meias</a>
      <a href="shop.html?cat=accessories&sub=bags" onclick="toggleMobileNav()">Mochilas &amp; Bags</a>
    </div>
  </div>
  <a href="shop.html?filter=brands" onclick="toggleMobileNav()">Marcas</a>
  <a href="shop.html?filter=outfits" onclick="toggleMobileNav()">Outfits</a>
  <a href="../index.html#releases" onclick="toggleMobileNav()">Drops</a>
  <a href="shop.html?filter=sale" onclick="toggleMobileNav()" style="color:#e53935">Saldos</a>
</nav>

<div class="page-hero" style="background-image:url('https://picsum.photos/seed/gspages/1920/400')">
  <div class="page-hero-overlay"></div>
  <div class="container page-hero-content">
    <p class="breadcrumb"><a href="../index.html">Início</a> / Sobre Nós</p>
    <h1>SOBRE NÓS</h1>
    <p>A história por trás da melhor loja de sneakers da Península Ibérica.</p>
  </div>
</div>

<!-- ABOUT CONTENT -->
<section class="section">
  <div class="container">
    <div class="about-grid">
      <div class="about-text">
        <p class="section-eyebrow">A nossa história</p>
        <h2 class="section-title" style="font-size:2.5rem">NASCEMOS DA PAIXÃO<br>POR SNEAKERS.</h2>
        <p>A Global Supply nasceu da frustração de não encontrar os sneakers certos, em Portugal, a tempo. Cansados de esperar semanas por encomendas internacionais ou de pagar preços absurdos a revendedores sem suporte, decidimos criar a solução.</p>
        <p style="margin-top:1rem">A nossa missão é simples: trazer os melhores modelos do mercado — Nike, Jordan, Adidas, New Balance e muito mais — direto para ti, com entrega em 24-48h e atendimento real.</p>
        <p style="margin-top:1rem">Somos uma equipa jovem, movida pela cultura sneaker e pelo respeito pelo cliente. Cada encomenda é tratada como se fosse nossa.</p>
      </div>
      <div class="about-image">
        <img src="https://picsum.photos/seed/gsabout/800/500" alt="Global Supply">
      </div>
    </div>
  </div>
</section>

<!-- VALUES -->
<section class="section section-dark">
  <div class="container">
    <div class="section-header centered">
      <p class="section-eyebrow">Os nossos pilares</p>
      <h2 class="section-title">POR QUE ESCOLHER A GLOBAL SUPPLY</h2>
    </div>
    <div class="values-grid">
      <div class="value-card">
        <i class="fas fa-shipping-fast"></i>
        <h3>Velocidade</h3>
        <p>Envio em 24-48h para Portugal e Espanha. Rastreamento em tempo real com cada encomenda.</p>
      </div>
      <div class="value-card">
        <i class="fas fa-check-circle"></i>
        <h3>Qualidade</h3>
        <p>Todos os produtos são verificados individualmente antes de saírem do nosso armazém.</p>
      </div>
      <div class="value-card">
        <i class="fas fa-headset"></i>
        <h3>Suporte Real</h3>
        <p>Respondemos via WhatsApp e Instagram em menos de 2 horas. Todos os dias, incluindo fins de semana.</p>
      </div>
      <div class="value-card">
        <i class="fas fa-users"></i>
        <h3>Comunidade</h3>
        <p>+2000 clientes satisfeitos. Uma família de sneakerheads que cresce a cada drop.</p>
      </div>
    </div>
  </div>
</section>

<!-- STATS -->
<section class="section">
  <div class="container">
    <div class="stats-row">
      <div class="stat-big">
        <span class="stat-big-num">+2000</span>
        <span class="stat-big-label">Clientes Felizes</span>
      </div>
      <div class="stat-big">
        <span class="stat-big-num">100%</span>
        <span class="stat-big-label">Feedback Positivo</span>
      </div>
      <div class="stat-big">
        <span class="stat-big-num">42</span>
        <span class="stat-big-label">Modelos em Catálogo</span>
      </div>
      <div class="stat-big">
        <span class="stat-big-num">24h</span>
        <span class="stat-big-label">Tempo Médio Entrega</span>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-section">
  <div class="container cta-inner">
    <h2>PRONTO PARA O TEU PRÓXIMO PAR?</h2>
    <p>Explora o catálogo e encontra o sneaker que procuras.</p>
    <a href="shop.html" class="btn btn-primary btn-lg">Ver Catálogo</a>
  </div>
</section>

