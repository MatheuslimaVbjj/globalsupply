<div class="cart-overlay" id="cart-overlay"></div>
<div class="cart-sidebar" id="cart-sidebar">
  <div class="cart-header">
    <h3>O Teu Carrinho</h3>
    <button onclick="closeCart()" class="cart-close">✕</button>
  </div>
  <div class="cart-items" id="cart-items"></div>
  <div class="cart-footer" id="cart-footer" style="display:none">
    <div class="cart-total"><span>Total</span><span id="cart-total-price">—</span></div>
    <a href="contact.html" class="btn btn-primary" style="width:100%;justify-content:center;margin-top:1rem">Finalizar via WhatsApp</a>
    <button onclick="cart.clear()" class="btn btn-dark" style="width:100%;justify-content:center;margin-top:.75rem">Limpar</button>
  </div>
</div>

<div class="size-modal-overlay" id="size-modal-overlay" onclick="if(event.target===this)closeSizeModal()">
  <div class="size-modal">
    <button class="size-modal-close" onclick="closeSizeModal()">✕</button>
    <div class="size-modal-product">
      <img id="modal-product-img" src="" alt="">
      <div>
        <div id="modal-product-brand" style="color:var(--accent);font-size:.8rem;font-weight:600;margin-bottom:.25rem"></div>
        <div id="modal-product-name" style="font-family:'Oswald',sans-serif;font-size:1.3rem;font-weight:700"></div>
      </div>
    </div>
    <div class="size-grid" id="modal-size-grid"></div>
    <div style="display:flex;gap:.75rem;margin-top:1.5rem">
      <button class="btn btn-primary" style="flex:1;justify-content:center" onclick="confirmAddToCart()">Adicionar</button>
      <button class="btn btn-dark" onclick="closeSizeModal()">Cancelar</button>
    </div>
  </div>
</div>

<button class="scroll-top" id="scroll-top" aria-label="Topo">↑</button>
